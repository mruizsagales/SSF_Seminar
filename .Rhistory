polygon_terra <- vect(naMap_bo_filt1) # convert sf object to SpatVector
polygon_terra <- project(polygon_terra, crs(iso_marine)) # harmonitzar CRS amb l'isoscape
# crear rectangle i tallar realment el polígon
extent_pol <- ext(-80, 40, 0, 85)
ext_poly <- as.polygons(extent_pol, crs = crs(polygon_terra))
naMap1 <- intersect(polygon_terra, ext_poly)
# punts
sv <- vect(sites[, -1], geom = c("lon", "lat"), crs = "EPSG:4326")
# calRaster amb mask com a SpatVector
d2h_Ll <- assignR::calRaster(
sv,
iso_marine,
interpMethod = 2,
ignore.NA = TRUE,
genplot = TRUE,
verboseLM = TRUE,
mask = naMap1
)
mean_masked <- mask(d2h_Ll$isoscape.rescale$mean, naMap1)
sd_masked   <- mask(d2h_Ll$isoscape.rescale$sd, naMap1)
plot(mean_masked)
plot(sd_masked)
# area
a <- sites %>% group_by(site) %>% summarise(mean(meas,na.rm=T), sd(meas,na.rm=T))
a$data <- "dO"
a <- as.data.frame(a)
a$SD <- 0.1
Ll_prob = pdRaster(d2h_Ll, a)
plot(Ll_prob$Galicia)
plot(Ll_prob$Islandia)
qtlRaster(Ll_prob$Galicia, threshold = 0.25)
qtlRaster(Ll_prob$Islandia, threshold = 0.25)
# quality analyis
qa1 = QA(sv, iso_marine, valiStation = 8, valiTime = 4, by = 5, mask = naMap1, name = "normal", bySite=F)
plot(qa1)
# for iceland vs Galicia
# Extract your two SpatRaster layers
r1 <- Ll_prob$Galicia
r2 <- Ll_prob$Islandia
# Convert to data frames and tag an id
df1 <- as.data.frame(r1, xy = TRUE, na.rm = TRUE); names(df1)[3] <- "prob"; df1$id <- "1"
df2 <- as.data.frame(r2, xy = TRUE, na.rm = TRUE); names(df2)[3] <- "prob"; df2$id <- "2"
dfr <- rbind(df1, df2)
# World polygons (WGS84)
world <- ne_countries(scale = 'large', returnclass = "sf") |>
st_transform(4326)
# Common limits so both facets share the same color scale
lim_max <- max(dfr$prob, na.rm = TRUE)
library(sf)
e <- ext(Ll_prob[[1]])
xlim <- c(e$xmin, e$xmax)
ylim <- c(e$ymin, e$ymax)
ggplot(dfr, aes(x = x, y = y, fill = prob)) +
geom_raster(interpolate = FALSE, alpha= 0.9) +
geom_sf(data = world, fill = "grey", color = "grey20", linewidth = 0.2,inherit.aes = FALSE) +
coord_sf(xlim = xlim, ylim = ylim, expand = FALSE) +
scale_fill_viridis_c(name = "Probability", limits = c(0, lim_max), oob = scales::squish) +
facet_wrap(~ id, nrow = 1, labeller = label_both) +
theme_article(base_size = 10, base_family = "Optima") +
theme(panel.grid = element_blank(),
legend.position = "right") + theme(
panel.grid = element_blank(),
legend.position = "right",
# ↑ increase the gap between facet panels (horizontal & vertical)
panel.spacing.x = unit(1.2, "cm"),
panel.spacing.y = unit(0.8, "cm")
# (optional) add whitespace around the whole plot
)
# --- inputs ---------------------------------------------------------------
r1 <- Ll_prob[[1]]
r2 <- Ll_prob[[2]] #maps that show the 25% of grid cells with the highest posterior probability for each sample
thr <- 0.25  # e.g., top 20% cumulative probability region
# HPD/quantile masks (1 inside, NA outside)
m1 <- assignR::qtlRaster(r1, threshold = thr)
m2 <- assignR::qtlRaster(r2, threshold = thr)
plot(m1)
plot(m2)
thr <- 0.05  # e.g., top 20% cumulative probability region
# HPD/quantile masks (1 inside, NA outside)
m1 <- assignR::qtlRaster(r1, threshold = thr)
m2 <- assignR::qtlRaster(r2, threshold = thr)
plot(m1)
plot(m2)
# Stack prob + mask, then to data frames
s1 <- c(r1, m1); names(s1) <- c("prob","in_qtl")
s2 <- c(r2, m2); names(s2) <- c("prob","in_qtl")
df1 <- as.data.frame(s1, xy = TRUE) %>%
mutate(id = "1",
in_qtl = ifelse(is.na(in_qtl) | in_qtl == 0, "outside", "inside"))
df2 <- as.data.frame(s2, xy = TRUE) %>%
mutate(id = "2",
in_qtl = ifelse(is.na(in_qtl) | in_qtl == 0, "outside", "inside"))
dfr <- bind_rows(df1, df2)
# World + extent from the raster
world <- ne_countries(scale = 'large', returnclass = "sf") |> st_transform(4326)
e <- ext(Ll_prob[[1]]); xlim <- c(e$xmin, e$xmax); ylim <- c(e$ymin, e$ymax)
# --- plot: fade the HPD region (inside) by lowering alpha -----------------
m1_a <- dfr %>% dplyr::filter(id == 1)
lim_maxa <- max(m1_a$prob, na.rm = TRUE)
m1_b <- dfr %>% dplyr::filter(id == 2)
lim_maxb <- max(m1_b$prob, na.rm = TRUE)
aa <- ggplot() +
geom_raster(data = m1_a, aes(x = x, y = y, fill = prob, alpha = in_qtl),
interpolate = FALSE) +
# choose which side is more transparent:
#   inside=0.35, outside=0.95  -> HPD region lighter
#   inside=0.95, outside=0.35  -> HPD region highlighted
scale_alpha_manual(values = c(inside = 1, outside = 0.8), guide = "none") +
geom_sf(data = world, fill = "grey90", color = "grey20", linewidth = 0.2,
inherit.aes = FALSE) +
coord_sf(xlim = xlim, ylim = ylim, expand = FALSE) +
scale_fill_viridis_c(name = "Probability", limits = c(0, lim_maxa),
oob = scales::squish) +
#facet_wrap(~ id, nrow = 1, labeller = label_both) +
xlab("Latitude") + ylab("Longitude") +
theme_article(base_size = 10, base_family = "Optima") +
theme(panel.grid = element_blank(),
legend.position = "none",
panel.spacing.x = unit(1.2, "cm"),
panel.spacing.y = unit(0.8, "cm"),
plot.margin = ggplot2::margin(10, 20, 10, 20),
panel.border = element_rect(colour = "black", fill = NA, linewidth = 0.6)) + geom_contour(
data = subset(m1_a, !is.na(in_qtl)),
aes(x = x, y = y, z = as.integer(in_qtl == "inside")),
breaks = 0.5,                 # draw the boundary between inside (1) and outside (0)
linetype = "dotted",
color = "black",
linewidth = 0.4
)
bb <- ggplot() +
geom_raster(data = m1_b, aes(x = x, y = y, fill = prob, alpha = in_qtl),
interpolate = FALSE) +
# choose which side is more transparent:
#   inside=0.35, outside=0.95  -> HPD region lighter
#   inside=0.95, outside=0.35  -> HPD region highlighted
scale_alpha_manual(values = c(inside = 1, outside = 0.8), guide = "none") +
geom_sf(data = world, fill = "grey90", color = "grey20", linewidth = 0.2,
inherit.aes = FALSE) +
coord_sf(xlim = xlim, ylim = ylim, expand = FALSE) +
scale_fill_viridis_c(
name = "Probability",
limits = c(0, lim_maxa),
oob = scales::squish,
labels = scales::scientific_format(digits = 2)  # ← scientific tick labels
) +
guides(
fill = guide_colorbar(
direction = "vertical",
barwidth = grid::unit(3, "mm"),   # thinner bar
barheight = grid::unit(30, "mm"),
ticks = TRUE
)
)+
#facet_wrap(~ id, nrow = 1, labeller = label_both) +
xlab("Latitude") + ylab("Longitude") +
theme_article(base_size = 10, base_family = "Optima") +
theme(panel.grid = element_blank(),
legend.position = "right",
panel.spacing.x = unit(1.2, "cm"),
panel.spacing.y = unit(0.8, "cm"),
plot.margin = ggplot2::margin(10, 20, 10, 20),
panel.border = element_rect(colour = "black", fill = NA, linewidth = 0.6)) + geom_contour(
data = subset(m1_b, !is.na(in_qtl)),
aes(x = x, y = y, z = as.integer(in_qtl == "inside")),
breaks = 0.5,                 # draw the boundary between inside (1) and outside (0)
linetype = "dotted",
color = "black",
linewidth = 0.4
)
junts <- aa + bb + plot_annotation(tag_levels = 'a')
junts
