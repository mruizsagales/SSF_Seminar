plot(r0, main = expression(paste("Mean ", delta^{18}, "O (0–125 m, unweighted)")))
# data from bone stable isotopes in Iceland and Galicia
data_paper_morgana <- read_excel("/Users/marcruizisagales/Downloads/BPHY HUESO Fluor Isotopos y Metales.xls", skip = 1)
# coordinates & measured values (permil, VSMOW)
sites <- data.frame(site= data_paper_morgana$Area,
lon = c(rnorm(24, mean = -27, sd = 0.5),rnorm(59, mean = -11.5, sd = 0.5)),
lat = c(rnorm(24, mean = 64, sd = 1),rnorm(59, mean = 43, sd = 1)),
meas= data_paper_morgana$dO)
sites <- na.omit(sites)
sites %>% dplyr::group_by(site) %>% dplyr::summarise(n())
# 3) Make a SpatVector in the same CRS
pts <- vect(sites, geom = c("lon", "lat"), crs = crs(r0))
# 4) Extract raster values (nearest cell and bilinear)
val_near  <- terra::extract(r0, pts, method = "simple")[,2]
val_bilin <- terra::extract(r0, pts, method = "bilinear")[,2]
# 5) Combine and compute differences
out <- cbind(
sites,
raster_nearest = val_near,
raster_bilinear = val_bilin
)
print(out, digits = 4)
ggplot(out, aes(raster_nearest, meas)) + geom_point() + geom_smooth(method="lm")
# coordinates & measured values (permil, VSMOW)
sites <- data.frame(site= data_paper_morgana$Area,
lon = c(rnorm(24, mean = -27, sd = 0.5),rnorm(59, mean = -11.5, sd = 0.5)),
lat = c(rnorm(24, mean = 64, sd = 0.5),rnorm(59, mean = 43, sd = 0.5)),
meas= data_paper_morgana$dO)
sites <- na.omit(sites)
sites %>% dplyr::group_by(site) %>% dplyr::summarise(n())
# 3) Make a SpatVector in the same CRS
pts <- vect(sites, geom = c("lon", "lat"), crs = crs(r0))
# 4) Extract raster values (nearest cell and bilinear)
val_near  <- terra::extract(r0, pts, method = "simple")[,2]
val_bilin <- terra::extract(r0, pts, method = "bilinear")[,2]
# 5) Combine and compute differences
out <- cbind(
sites,
raster_nearest = val_near,
raster_bilinear = val_bilin
)
print(out, digits = 4)
ggplot(out, aes(raster_nearest, meas)) + geom_point() + geom_smooth(method="lm")
ggplot(out, aes(raster_bilinear,meas)) + geom_point() + geom_smooth(method="lm")
# formula
# Fit the two models
m_near  <- lm(meas ~ raster_nearest, data = out)
m_bilin <- lm(meas ~ raster_bilinear, data = out)
summary(m_near) # intercept = 29.4320; slope = 0.8286
summary(m_bilin) # intercept = 29.4359; slope = 0.8205
# Coefs
b0n <- unname(coef(m_near)[1])
b1n <- unname(coef(m_near)[2])
b0b <- unname(coef(m_bilin)[1])
b1b <- unname(coef(m_bilin)[2])
# R^2
r2n <- summary(m_near)$r.squared
r2b <- summary(m_bilin)$r.squared
confint(m_near)
ci_near  <- confint(m_near)["raster_nearest", ]
ci_bilin <- confint(m_bilin)["raster_bilinear", ]
# Nicely formatted equations
eq_near <- sprintf(
"meas = %.3f + %.3f × raster_nearest (R² = %.3f; slope 95%% CI: [%.3f, %.3f])",
b0n, b1n, r2n, ci_near[1], ci_near[2]
)
eq_bilin <- sprintf(
"meas = %.3f + %.3f × raster_bilinear (R² = %.3f; slope 95%% CI: [%.3f, %.3f])",
b0b, b1b, r2b, ci_bilin[1], ci_bilin[2]
)
cat(eq_near, "\n")
cat(eq_bilin, "\n")
marine <- r0  # change if your object has a different name
a  <- b0n + mean_diff
#a_low  <- b0n + (1.01 - 0.675)
#a_high <- b0n + (1.01 + 0.675)
b  <- b1n
d18O_sc_mean <- a + b * marine
names(d18O_sc_mean) <- "mean"
plot(d18O_sc_mean)
marine_sd  <- marine * 0 + 1
sa <- summary(m_near)$coefficients["(Intercept)", "Std. Error"]
sb <- summary(m_near)$coefficients["raster_nearest", "Std. Error"]
d18O_sc_sd <- sqrt(
sa^2 +
(marine^2) * sb^2 +
(b^2) * marine_sd^2 +
sd_diff^2
)
iso_marine <- c(d18O_sc_mean, d18O_sc_sd)
names(iso_marine) <- c("mean", "sd")
# mask
#naMap_bo <- read_sf("/Users/marcruizisagales/Downloads/GOaS_v1_20211214/goas_v01.shp") # ocean basin polygons
